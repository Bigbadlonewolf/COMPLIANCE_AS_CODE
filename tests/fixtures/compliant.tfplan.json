    {
      "address": "google_project_iam_member.app_log_writer",
      "type": "google_project_iam_member",
      "provider_name": "registry.terraform.io/hashicorp/google",
      "change": {
        "actions": ["create"],
        "after": {
          "project": "example-project",
          "role": "roles/logging.logWriter",
          "member": "serviceAccount:sa-app@example-project.iam.gserviceaccount.com"
        }
      }
    }
  ]
