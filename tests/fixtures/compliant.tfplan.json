        "actions": ["create"],
        "after": {
          "direction": "INGRESS",
          "disabled": false,
          "name": "deny-all-ingress",
          "network": "projects/example-project/global/networks/default",
          "priority": 65534,
          "source_ranges": ["0.0.0.0/0"],
          "allow": [],
          "deny": [{"protocol": "all", "ports": []}]
        }
      }
    },
    {
      "address": "google_compute_firewall.allow_internal",
      "type": "google_compute_firewall",
      "provider_name": "registry.terraform.io/hashicorp/google",
      "change": {
        "actions": ["create"],
        "after": {
          "direction": "INGRESS",
          "disabled": false,
          "name": "allow-internal",
          "network": "projects/example-project/global/networks/default",
          "priority": 1000,
          "source_ranges": ["10.0.0.0/8"],
          "allow": [
            {"protocol": "tcp", "ports": []},
            {"protocol": "udp", "ports": []},
            {"protocol": "icmp", "ports": []}
          ],
          "deny": []
        }
      }
    },
    {
      "address": "google_kms_crypto_key.sql",
      "type": "google_kms_crypto_key",
      "provider_name": "registry.terraform.io/hashicorp/google",
      "change": {
        "actions": ["create"],
        "after": {
          "name": "cloud-sql-key",
          "key_ring": "projects/example-project/locations/us-central1/keyRings/cde-keyring",
          "purpose": "ENCRYPT_DECRYPT",
          "rotation_period": "7776000s"
        }
      }
    },
    {
      "address": "google_kms_crypto_key.gcs",
      "type": "google_kms_crypto_key",
      "provider_name": "registry.terraform.io/hashicorp/google",
      "change": {
        "actions": ["create"],
        "after": {
          "name": "gcs-audit-key",
          "key_ring": "projects/example-project/locations/us-central1/keyRings/cde-keyring",
          "purpose": "ENCRYPT_DECRYPT",
          "rotation_period": "7776000s"
        }
      }
    },
    {
      "address": "google_sql_database_instance.main",
      "type": "google_sql_database_instance",
      "provider_name": "registry.terraform.io/hashicorp/google",
      "change": {
        "actions": ["create"],
        "after": {
          "name": "cde-db",
          "database_version": "POSTGRES_15",
          "region": "us-central1",
          "deletion_protection": true,
          "encryption_key_name": "projects/example-project/locations/us-central1/keyRings/cde-keyring/cryptoKeys/cloud-sql-key",
          "settings": [
            {
              "tier": "db-n1-standard-2",
              "availability_type": "REGIONAL",
              "ip_configuration": [
                {
                  "ipv4_enabled": false,
                  "ssl_mode": "ENCRYPTED_ONLY",
                  "private_network": "projects/example-project/global/networks/default"
                }
              ],
              "backup_configuration": [
                {
                  "enabled": true,
                  "point_in_time_recovery_enabled": true,
                  "start_time": "02:00",
                  "transaction_log_retention_days": 7
                }
              ],
              "database_flags": [
                {"name": "cloudsql.enable_pgaudit", "value": "on"},
                {"name": "log_connections", "value": "on"},
                {"name": "log_disconnections", "value": "on"},
                {"name": "log_statement", "value": "ddl"}
              ]
            }
          ]
        }
      }
    },
    {
      "address": "google_storage_bucket.audit_logs",
      "type": "google_storage_bucket",
      "provider_name": "registry.terraform.io/hashicorp/google",
      "change": {
        "actions": ["create"],
        "after": {
          "name": "example-project-audit-logs",
          "location": "US-CENTRAL1",
          "uniform_bucket_level_access": true,
          "public_access_prevention": "enforced",
          "encryption": [
            {
              "default_kms_key_name": "projects/example-project/locations/us-central1/keyRings/cde-keyring/cryptoKeys/gcs-audit-key"
            }
          ],
          "versioning": [{"enabled": true}],
          "retention_policy": [{"is_locked": true, "retention_period": 31536000}],
          "lifecycle_rule": [
            {
              "condition": [{"age": 90}],
              "action": [{"type": "SetStorageClass", "storage_class": "COLDLINE"}]
            }
          ]
        }
      }
    },
    {
      "address": "google_project_iam_member.app_sql_client",
